  "main": "app.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:w": "tsc -w",
    "start": "node ./dist/app.js",
    "dev": "concurrently \"npm:build:w\" \"npm:start\"",
    "docker:dev": "npm run build && npm start",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "docs": "typedoc src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.1",
    "@types/p-retry": "^3.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
