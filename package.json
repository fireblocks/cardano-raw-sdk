{
  "name": "cardano-raw-sdk",
  "version": "1.4.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "build:w": "tsc -w",
    "start": "node ./dist/app.js",
    "dev": "concurrently \"npm:build:w\" \"npm:start\"",
    "docker:dev": "npm run build && npm start",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "docs": "typedoc src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
    "@fireblocks/ts-sdk": "^12.1.1",
    "axios": "^1.10.0",
    "bech32": "^2.0.0",
    "blakejs": "^1.2.1",
    "cbor2": "^2.0.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jose": "^6.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.13"
  }
}
