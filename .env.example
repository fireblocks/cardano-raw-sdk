# ============================================================
# Cardano Raw SDK - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env or any real credentials to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8000
NODE_ENV=production   # Set to "development" only when using self-signed certs locally

# ── Fireblocks (Required) ────────────────────────────────────
FIREBLOCKS_API_USER_KEY=<your-fireblocks-api-key>
FIREBLOCKS_API_USER_SECRET_KEY_PATH=<FULL/PATH/TO/fireblocks_secret.key>

# Base path for your Fireblocks workspace. Affects webhook JWKS region.
# US (default): https://api.fireblocks.io (see https://developers.fireblocks.com/reference/typescript-sdk for additional environments URLs)
FIREBLOCKS_BASE_PATH=https://api.fireblocks.io

# ── Iagon API (Required) ─────────────────────────────────────
IAGON_API_KEY=<your-iagon-api-key>

# ── Cardano Network ──────────────────────────────────────────
# Cardano network configuration (mainnet, preprod, preview) - defaults to mainnet
CARDANO_NETWORK=mainnet
