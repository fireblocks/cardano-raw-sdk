PORT=8000
CLIENT_PORT=

## Mandatory Fireblocks configurations
FIREBLOCKS_API_KEY= "1234abcd-1234-abcd-1234-abcd1234"
FIREBLOCKS_API_PATH_TO_SECRET= "<FULL/PATH/TO/fireblocks_secret.key>"

# Defaults to US-Prod environment ("https://api.fireblocks.io") if not provided, go to https://developers.fireblocks.com/reference/typescript-sdk for additional environments URLs
FIREBLOCKS_BASE_PATH=

# Cardano network configuration (mainnet, preprod, preview) - defaults to mainnet
CARDANO_NETWORK=mainnet

# SDK Pool configuration
POOL_MAX_SIZE=100
POOL_IDLE_TIMEOUT_MS=1800000
POOL_CLEANUP_INTERVAL_MS=300000
POOL_CONNECTION_TIMEOUT_MS=30000
POOL_RETRY_ATTEMPTS=3

# Blockfrost API project ID
BLOCKFROST_PROJECT_ID=

# Iagon API key for transaction details and enrichment
IAGON_API_KEY=